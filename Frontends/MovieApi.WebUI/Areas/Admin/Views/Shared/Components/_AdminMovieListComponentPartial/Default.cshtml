<div class="films-table">
    <table>
        <thead>
            <tr>
                <th>#</th>
                <th>Film Adı</th>
                <th>Yıl</th>
                <th>Süre</th>
                <th>IMDB</th>
                <th>Durum</th>
                <th>İşlemler</th>
            </tr>
        </thead>
        <tbody id="filmsTableBody">
        </tbody>
    </table>
</div>
<!-- Pagination -->
<div class="pagination-wrapper">
    <div class="pagination-info">
        Toplam <strong id="sizeMovie">156</strong> filmden <strong>1-10</strong> arası gösteriliyor
    </div>

    <ul class="pagination">
        <li class="disabled">
            <a href="#" onclick="changePage(16,event); return false;">
                <i class="fas fa-angle-double-left"></i>
            </a>
        </li>
        <li class="disabled">
            <a href="#" onclick="changePage(event); return false;">
                <i class="fas fa-angle-left"></i>
            </a>
        </li>
        <li class="active"><a href="#" onclick="changePage(event); return false;">1</a></li>
        <li><a href="#" onclick="changePage(event); return false;">2</a></li>
        <li><a href="#" onclick="changePage(event); return false;">3</a></li>
        <li><a href="#" onclick="changePage(event); return false;">4</a></li>
        <li><a href="#" onclick="changePage(event); return false;">5</a></li>
        <li>
            <a href="#" onclick="changePage(event); return false;">
                <i class="fas fa-angle-right"></i>
            </a>
        </li>
        <li>
            <a href="#" onclick="changePage(16,event); return false;">
                <i class="fas fa-angle-double-right"></i>
            </a>
        </li>
    </ul>

    <div class="page-size-selector">
        <label>Sayfa başına:</label>
        <select id="pageSize" onchange="changePageSize()">
            <option value="10" selected>10</option>
            <option value="25">25</option>
            <option value="50">50</option>
            <option value="100">100</option>
        </select>
    </div>
</div>